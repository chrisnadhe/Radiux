# ===========================================================================
# Radiux — Environment Variables
# Salin file ini ke .env dan sesuaikan nilainya.
# JANGAN commit file .env ke repository!
# ===========================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_ENV=development
DEBUG=true
SECRET_KEY=GANTI_DENGAN_RANDOM_STRING_PANJANG_DAN_AMAN_MINIMAL_32_KARAKTER
ALLOWED_HOSTS=localhost,127.0.0.1

# ---------------------------------------------------------------------------
# Database (PostgreSQL — shared antara Radiux & FreeRADIUS)
# ---------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=radiux_db
POSTGRES_USER=radiux_user
POSTGRES_PASSWORD=GANTI_DENGAN_PASSWORD_KUAT

# Database URL (otomatis dibentuk dari variabel di atas, atau bisa override manual)
# DATABASE_URL=postgresql+psycopg://radiux_user:password@postgres:5432/radiux_db

# ---------------------------------------------------------------------------
# RADIUS
# ---------------------------------------------------------------------------
# Shared secret default untuk NAS baru — ubah setelah produksi
RADIUS_DEFAULT_SECRET=GANTI_DENGAN_SHARED_SECRET

# ---------------------------------------------------------------------------
# Redis (background jobs & cache — belum digunakan di Phase 0)
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ---------------------------------------------------------------------------
# JWT
# ---------------------------------------------------------------------------
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# ---------------------------------------------------------------------------
# Notifikasi (Phase 8)
# ---------------------------------------------------------------------------
# TELEGRAM_BOT_TOKEN="token_dari_botfather"
# TELEGRAM_ADMIN_CHAT_ID="id_chat_admin"
# NOTIFICATION_LOW_BALANCE_THRESHOLD=100000.0

# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASSWORD=
# SMTP_FROM=Radiux <noreply@example.com>

# WA_GATEWAY_URL=
# WA_GATEWAY_TOKEN=
